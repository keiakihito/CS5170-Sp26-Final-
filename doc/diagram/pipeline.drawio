        <mxCell id="em_fn" value="exact_match()&#xa;evaluate_exact_match()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="910" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- EvalSuite -->
        <mxCell id="evalsuite" value="EvalSuite&#xa;.add()  .best_approach()&#xa;.improvement_over_baseline()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="740" y="905" width="170" height="50" as="geometry" />
        </mxCell>

        <!-- ResultsVisualizer -->
