        </mxCell>
        <mxCell id="inf_filter" value="_filter_documents&#xa;thresh=0.2 top-4 min-2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="745" width="130" height="40" as="geometry" />
