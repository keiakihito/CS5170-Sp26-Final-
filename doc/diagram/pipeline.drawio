        <!-- ================================================================
             STEP 4 — INFERENCE
        ================================================================ -->

        <!-- Query input -->
        <mxCell id="query_in" value="Query string" style="shape=parallelogram;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="750" width="110" height="40" as="geometry" />
        </mxCell>

        <!-- InferencePipeline steps -->
