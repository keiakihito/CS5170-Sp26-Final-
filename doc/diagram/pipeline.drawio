        <mxCell id="qcat" value="QueryCategorizer&#xa;(Qwen2.5-7B)&#xa;.categorize(query, answer)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="260" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- QueryResult -->
        <mxCell id="qresult" value="QueryResult&#xa;type: EASY | HARD&#xa;confidence: float" style="shape=parallelogram;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="260" width="150" height="50" as="geometry" />
        </mxCell>

        <!-- Confidence threshold note -->
        <mxCell id="conf_note" value="threshold = 0.5" style="text;html=1;strokeColor=none;fillColor=#fff2cc;align=center;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="560" y="318" width="160" height="20" as="geometry" />
