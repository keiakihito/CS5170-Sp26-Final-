        <mxCell id="title" value="InfoGain-RAG — Full Pipeline" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="800" height="40" as="geometry" />
        </mxCell>

        <!-- ================================================================
             SWIM LANE LABELS (left column)
        ================================================================ -->
        <mxCell id="lane0_label" value="Step 0&#xa;Preprocess" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="20" y="80" width="100" height="140" as="geometry" />
        </mxCell>
        <mxCell id="lane1_label" value="Step 1&#xa;Query&#xa;Categorize" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="20" y="240" width="100" height="140" as="geometry" />
        </mxCell>
        <mxCell id="lane2_label" value="Step 2&#xa;DIG&#xa;Scoring" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="20" y="400" width="100" height="140" as="geometry" />
        </mxCell>
        <mxCell id="lane3_label" value="Step 3&#xa;Reranker&#xa;Training" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="20" y="560" width="100" height="140" as="geometry" />
        </mxCell>
        <mxCell id="lane4_label" value="Step 4&#xa;Inference" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="20" y="720" width="100" height="140" as="geometry" />
        </mxCell>
        <mxCell id="lane5_label" value="Step 5&#xa;Evaluation" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="20" y="880" width="100" height="140" as="geometry" />
        </mxCell>

        <!-- ================================================================
             STEP 0 — PREPROCESSING
        ================================================================ -->

        <!-- Data sources -->
        <mxCell id="triviaqa" value="TriviaQA&#xa;(HF Hub cache)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="90" width="110" height="60" as="geometry" />
        </mxCell>
        <mxCell id="wikipedia" value="Wikipedia Dump&#xa;psgs_w100.tsv.gz" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="90" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- WikipediaCorpus -->
        <mxCell id="wiki_corpus" value="WikipediaCorpus&#xa;.get_passage(doc_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="170" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- ContrieverRetriever -->
        <mxCell id="contriever" value="ContrieverRetriever&#xa;(facebook/contriever-msmarco)&#xa;.retrieve(query, top_k=100)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="90" width="170" height="50" as="geometry" />
        </mxCell>

        <!-- Preprocessor -->
        <mxCell id="preprocessor" value="Preprocessor&#xa;.load_triviaqa()&#xa;.build_triplets()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="630" y="90" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- Triplet output -->
        <mxCell id="triplets" value="List[Triplet]&#xa;(query, answer,&#xa;doc_id, doc_text)" style="shape=parallelogram;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="790" y="90" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- Step 0 arrows -->
        <mxCell id="e_tqa_pre" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="triviaqa" target="preprocessor" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_wiki_corpus" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="wikipedia" target="wiki_corpus" parent="1">
          <mxGeometry relative="1" as="geometry" />
