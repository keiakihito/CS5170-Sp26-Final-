          <mxGeometry x="280" y="745" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="inf_score" value="_score_documents&#xa;(reranker)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
