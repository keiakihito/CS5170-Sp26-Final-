        </mxCell>

        <!-- Trained model -->
        <mxCell id="trained_model" value="reranker.pt&#xa;(trained weights)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1000" y="580" width="110" height="60" as="geometry" />
        </mxCell>

        <!-- Step 3 arrows -->
        <mxCell id="e_digres_tbatch" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="digresult" target="tbatch" parent="1">
