        </mxCell>

        <!-- InferenceResult -->
        <mxCell id="inf_result" value="InferenceResult&#xa;query, answer&#xa;ranked_docs, selected_docs" style="shape=parallelogram;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
