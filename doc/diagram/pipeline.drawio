        <mxCell id="e_qcat_qres" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="qcat" target="qresult" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ================================================================
             STEP 2 — DIG SCORING
        ================================================================ -->

        <!-- DIGScorer -->
        <mxCell id="dig" value="DIGScorer&#xa;(Qwen2.5-7B)&#xa;.compute_dig(query, answer, doc)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="420" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- DIG formula note -->
        <mxCell id="dig_note" value="DIG = p(y|x,d) − p(y|x)&#xa;smooth W=3, weight α=0.8^0.6" style="text;html=1;strokeColor=none;fillColor=#fff2cc;align=center;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="540" y="472" width="180" height="28" as="geometry" />
        </mxCell>

        <!-- DIGResult -->
        <mxCell id="digresult" value="List[DIGResult]&#xa;category: POS|NEG|NEUTRAL&#xa;dig_score, confidence" style="shape=parallelogram;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="420" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Thresholds note -->
        <mxCell id="thresh_note" value="b1=0.5 → POS   b2=−0.2 → NEG" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="750" y="472" width="160" height="20" as="geometry" />
        </mxCell>

        <!-- Step 2 arrows -->
        <mxCell id="e_trip_dig" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="triplets" target="dig" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_qres_dig" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="qresult" target="dig" parent="1">
